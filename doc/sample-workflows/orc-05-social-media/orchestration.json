{
  "_version": "1.0.0",
  "orchestratorName": "ORC-05: Social Media Pack Generator",
  "orchestratorDescription": "Multi-stage pipeline that distills core marketing messages and adapts them for LinkedIn, X, Threads, and FB/IG.",
  "steps": [
    {
      "id": "step_A",
      "name": "A",
      "label": "Message Distiller",
      "stage_key": "distiller",
      "task_type": "marketing_analysis",
      "cardinality": "1:1",
      "dependsOn": [],
      "ai_settings": {
        "model_id": "gemini-1.5-flash-latest",
        "generationConfig": {
          "temperature": 0.5,
          "maxOutputTokens": 2048
        }
      }
    },
    {
      "id": "step_B",
      "name": "B",
      "label": "Platform Adapter",
      "stage_key": "adapter",
      "task_type": "content_adaptation",
      "cardinality": "1:N",
      "split_path": "output_data",
      "dependsOn": ["step_A"],
      "ai_settings": {
        "model_id": "gemini-1.5-flash-latest",
        "generationConfig": {
          "temperature": 1.1,
          "maxOutputTokens": 4096
        }
      }
    }
  ]
}
