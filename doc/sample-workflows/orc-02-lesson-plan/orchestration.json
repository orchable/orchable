{
  "_version": "1.0.0",
  "orchestratorName": "ORC-02: Smart Lesson Plan Builder",
  "orchestratorDescription": "3-stage pipeline generating pedagogical maps, activities, and a final validated lesson plan.",
  "steps": [
    {
      "id": "step_A",
      "name": "A",
      "label": "Pedagogical Mapper",
      "stage_key": "mapper",
      "task_type": "pedagogical_mapping",
      "cardinality": "1:1",
      "dependsOn": [],
      "ai_settings": {
        "model_id": "gemini-1.5-pro-latest",
        "generationConfig": {
          "temperature": 0.7,
          "maxOutputTokens": 4096
        }
      },
      "contract": {
        "input": {
          "fields": [
            {
              "name": "input_data",
              "type": "string",
              "required": true
            }
          ],
          "delimiters": { "start": "%%", "end": "%%" }
        }
      }
    },
    {
      "id": "step_B",
      "name": "B",
      "label": "Activity Designer",
      "stage_key": "designer",
      "task_type": "activity_design",
      "cardinality": "1:N",
      "split_path": "output_data",
      "dependsOn": ["step_A"],
      "ai_settings": {
        "model_id": "gemini-1.5-flash-latest",
        "generationConfig": {
          "temperature": 1.0,
          "maxOutputTokens": 8192
        }
      }
    },
    {
      "id": "step_C",
      "name": "C",
      "label": "Coherence Validator",
      "stage_key": "validator",
      "task_type": "lesson_qc",
      "cardinality": "N:1",
      "dependsOn": ["step_B"],
      "ai_settings": {
        "model_id": "gemini-1.5-flash-latest",
        "generationConfig": {
          "temperature": 0.3,
          "maxOutputTokens": 4096
        }
      }
    }
  ]
}
