{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://iostem.edu.vn/schemas/iostem-reference-data.json",
  "title": "iOStem Reference Data Schema",
  "description": "JSON Schema for iOStem question generation system validation",
  "version": "1.0.0",
  "lastUpdated": "2025-12-12",

  "definitions": {
    "courseCode": {
      "type": "string",
      "enum": ["TOAN", "TNXH", "KHOA_HOC", "KHTN", "VAT_LY", "HOA_HOC", "SINH_HOC", "CONG_NGHE", "TIN_HOC"],
      "description": "Course/Subject code"
    },

    "gradeCode": {
      "type": "string",
      "enum": ["G1", "G2", "G3", "G4", "G5", "G6", "G7", "G8", "G9", "G10", "G11", "G12"],
      "description": "Grade level code (G1=Grade 1, etc.)"
    },

    "gradeBand": {
      "type": "string",
      "enum": ["PRIMARY", "SECONDARY", "HIGH_SCHOOL"],
      "description": "Grade band grouping"
    },

    "bloomCode": {
      "type": "string",
      "enum": ["REMEMBER", "UNDERSTAND", "APPLY", "ANALYZE", "EVALUATE", "CREATE"],
      "description": "Bloom's Taxonomy cognitive level"
    },

    "difficultyCode": {
      "type": "string",
      "enum": ["VERY_EASY", "EASY", "MEDIUM", "HARD", "VERY_HARD"],
      "description": "Question difficulty level"
    },

    "knowledgeTypeCode": {
      "type": "string",
      "enum": ["FACTUAL", "CONCEPT", "PROCEDURAL", "META_COGNITIVE"],
      "description": "Knowledge dimension type"
    },

    "stemElementCode": {
      "type": "string",
      "enum": ["S", "T", "E", "M", "DA"],
      "description": "STEM element code (S=Science, T=Technology, E=Engineering, M=Math, DA=Digital Ability)"
    },

    "examRoundCode": {
      "type": "string",
      "enum": ["VONG_TU_LUYEN", "VONG_TRAI_NGHIEM", "VONG_TRUONG", "VONG_TINH", "VONG_QUOC_GIA"],
      "description": "Exam round code"
    },

    "sectionCode": {
      "type": "string",
      "enum": ["STEM_DA", "CT"],
      "description": "Exam section code (STEM_DA=STEM & Digital Ability, CT=Computational Thinking)"
    },

    "questionTypeCode": {
      "type": "string",
      "enum": [
        "MULTIPLE_CHOICE",
        "MULTIPLE_RESPONSE",
        "TRUE_FALSE",
        "FILL_IN_THE_BLANKS",
        "DRAG_AND_DROP",
        "SHORT_ANSWER",
        "NUMERIC",
        "SEQUENCE",
        "MATCHING"
      ],
      "description": "Question format type"
    },

    "contextCode": {
      "type": "string",
      "enum": [
        "THEO_ABS",
        "SPEC_CASE",
        "NAT_OBS",
        "TECH_ENG",
        "EXP_INV",
        "REAL_PROB",
        "DATA_MOD",
        "HIST_SCI",
        "INTERDISC",
        "HYPO_COMP"
      ],
      "description": "Question context type"
    },

    "weekCode": {
      "type": "string",
      "pattern": "^W([1-9]|[12][0-9]|3[0-5])$",
      "description": "Curriculum week code (W1-W35)"
    }
  },

  "coefficients": {
    "description": "Coefficient values for difficulty calculation",
    "bloom": {
      "REMEMBER": 1.0,
      "UNDERSTAND": 1.5,
      "APPLY": 2.0,
      "ANALYZE": 2.5,
      "EVALUATE": 3.0,
      "CREATE": 3.5
    },
    "knowledge": {
      "FACTUAL": 1.0,
      "CONCEPT": 1.5,
      "PROCEDURAL": 2.0,
      "META_COGNITIVE": 2.5
    },
    "format": {
      "MULTIPLE_CHOICE": 1.2,
      "MULTIPLE_RESPONSE": 1.3,
      "TRUE_FALSE": 1.1,
      "FILL_IN_THE_BLANKS": 1.7,
      "DRAG_AND_DROP": 1.5,
      "SHORT_ANSWER": 1.8,
      "NUMERIC": 1.6,
      "SEQUENCE": 1.3,
      "MATCHING": 1.4
    }
  },

  "difficultyRanges": {
    "description": "D score ranges for difficulty classification",
    "VERY_EASY": { "min": 1.0, "max": 2.0, "points": 1 },
    "EASY": { "min": 2.1, "max": 4.0, "points": 2 },
    "MEDIUM": { "min": 4.1, "max": 6.0, "points": 3 },
    "HARD": { "min": 6.1, "max": 8.0, "points": 4 },
    "VERY_HARD": { "min": 8.1, "max": 999, "points": 5 }
  },

