{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Orchestration Bundle",
  "description": "Schema for a complete orchestration bundle including metadata and step configurations",
  "type": "object",
  "required": ["_version", "orchestratorName", "steps"],
  "properties": {
    "_version": { "type": "string" },
    "orchestratorName": { "type": "string" },
    "orchestratorDescription": { "type": "string" },
    "steps": {
      "$ref": "orchestration.schema.json"
    }
  }
}
